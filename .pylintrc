[MAIN]
# Use all available CPU cores to speed up pylint
jobs = 0

# Allow loading of all C extensions
unsafe-load-any-extension = no

[MESSAGES CONTROL]
# Disable specific pylint messages that are too noisy or better handled by formatters
disable =
    # --- Style issues (better handled by a code formatter like black) ---
    C0303,  # trailing-whitespace
    C0301,  # line-too-long
    C0305,  # trailing-newlines
    # --- Duplicate code detection (too aggressive across a large codebase) ---
    R0801,  # duplicate-code

[FORMAT]
# Maximum number of characters on a single line (only relevant if C0301 is enabled)
max-line-length = 120

[BASIC]
# Good variable names which should always be accepted
good-names = i, j, k, v, e, _, df, el, db

[DESIGN]
# Maximum number of arguments for function / method (default is 5)
max-args = 10
# Maximum number of positional arguments for function / method
max-positional-arguments = 10
# Maximum number of locals for function / method body (default is 15)
max-locals = 25
# Maximum number of return / yield for function / method body (default is 6)
max-returns = 10
# Maximum number of branch for function / method body (default is 12)
max-branches = 20
# Maximum number of statements in function / method body (default is 50)
max-statements = 80
# Maximum number of attributes for a class (default is 7)
max-attributes = 15
